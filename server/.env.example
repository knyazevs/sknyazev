PORT=8080

# --- LLM (chat completions, OpenAI-compatible) ---
# Default: OpenRouter. For local Ollama: http://localhost:11434/v1
LLM_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_API_KEY=sk-or-...
LLM_MODEL=anthropic/claude-opus-4-7
CLASSIFIER_MODEL=openai/gpt-4o-mini

# --- Embeddings / TTS / ASR (OpenAI-compatible) ---
# Default: OpenAI. For local Ollama: http://localhost:11434/v1
EMBEDDING_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=sk-...
EMBEDDING_MODEL=text-embedding-3-small

# --- Content paths ---
DOCS_PATH=../docs
CODE_PATH=..
CACHE_PATH=.embedding-cache.json

# --- CORS ---
# Comma-separated list of allowed origins
CORS_ALLOWED_ORIGIN=http://localhost:4321,http://localhost:4322,http://localhost:4323,https://knyazevs.github.io

# --- Session auth (HMAC) ---
# Secret used to sign short-lived session tokens issued from /api/session.
# Generate with: openssl rand -hex 32
SESSION_SECRET=change-me-generate-with-openssl-rand-hex-32
