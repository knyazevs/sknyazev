{
  "name": "sknyazev",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "concurrently -n server,app -c cyan,magenta \"bun run dev:server\" \"bun run dev:app\"",
    "dev:server": "cd server && ./gradlew runReleaseExecutableLinuxX64",
    "dev:app": "cd app && bun run dev",
    "build:cv": "node --experimental-strip-types scripts/build-cv.ts",
    "build:app": "cd app && bun run build",
    "build": "bun run build:cv && bun run build:app"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "gray-matter": "^4.0.3",
    "marked": "^18.0.0",
    "puppeteer": "^24.40.0"
  }
}
