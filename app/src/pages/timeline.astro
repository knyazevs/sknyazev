---
import Layout from '../layouts/Layout.astro';
import { execSync } from 'child_process';

interface Commit {
  hash: string;
  date: string;
  author: string;
  message: string;
  type: string;
  scope: string;
  body: string;
}

function parseType(message: string): { type: string; scope: string; body: string } {
  const m = message.match(/^(feat|arch|fix|docs|infra|design|refactor)\(([^)]+)\):\s*(.+)$/);
  if (m) return { type: m[1], scope: m[2], body: m[3] };
  const m2 = message.match(/^(feat|arch|fix|docs|infra|design|refactor):\s*(.+)$/);
  if (m2) return { type: m2[1], scope: '', body: m2[2] };
  return { type: 'other', scope: '', body: message };
}

const TYPE_LABEL: Record<string, string> = {
  feat: 'Feature', arch: 'Architecture', fix: 'Fix',
  docs: 'Docs', infra: 'Infra', design: 'Design', refactor: 'Refactor', other: 'Commit',
};

let commits: Commit[] = [];
try {
  const raw = execSync(
    'git log --pretty=format:"%H|%ai|%aN|%s" --no-merges -n 60',
    { cwd: process.cwd(), encoding: 'utf-8' }
  );
  commits = raw.trim().split('\n').filter(Boolean).map(line => {
    const [hash, date, author, ...rest] = line.split('|');
    const message = rest.join('|');
    const { type, scope, body } = parseType(message);
    return {
      hash: hash.slice(0, 7),
      date: date.slice(0, 10),
      author,
      message,
      type,
      scope,
      body,
    };
  });
} catch {
  // git not available at build time — skip
}

// Group by date
const grouped = new Map<string, Commit[]>();
for (const c of commits) {
  if (!grouped.has(c.date)) grouped.set(c.date, []);
  grouped.get(c.date)!.push(c);
}
---

<Layout title="Timeline — Sergey Knyazev">
  <div class="page">
    <header class="page-header">
      <a href="/" class="back-link">
        <svg width="11" height="11" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
          <polyline points="10,3 5,8 10,13"/>
        </svg>
        Назад
      </a>
      <h1 class="page-title">История проекта</h1>
      <p class="page-sub">Git log — {commits.length} коммитов</p>
    </header>

    <div class="timeline">
      {Array.from(grouped.entries()).map(([date, day]) => (
        <div class="day-group">
          <div class="day-marker">
            <span class="day-date">{date}</span>
            <span class="day-count">{day.length} коммит{day.length === 1 ? '' : day.length < 5 ? 'а' : 'ов'}</span>
          </div>
          <div class="day-commits">
            {day.map(c => (
              <div class="commit" data-type={c.type}>
                <div class="commit-dot"></div>
                <div class="commit-content">
                  <div class="commit-top">
                    {c.scope && <span class="commit-scope">{c.scope}</span>}
                    <span class="commit-body">{c.body}</span>
                    <span class="commit-hash">{c.hash}</span>
                  </div>
                  <span class="commit-type">{TYPE_LABEL[c.type] ?? c.type}</span>
                </div>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</Layout>

<style>
  .page {
    max-width: 720px;
    margin: 0 auto;
    padding: 32px 24px 80px;
  }

  .page-header {
    margin-bottom: 40px;
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    color: var(--color-text-dim);
    font-size: 11px;
    font-family: var(--font-mono);
    text-decoration: none;
    margin-bottom: 16px;
    transition: color 0.15s;
  }

  .back-link:hover { color: var(--color-accent); }

  .page-title {
    font-size: 22px;
    font-weight: 700;
    color: var(--color-text-heading);
    margin: 0 0 6px;
    letter-spacing: -0.02em;
  }

  .page-sub {
    font-size: 12px;
    font-family: var(--font-mono);
    color: var(--color-text-dim);
    margin: 0;
  }

  /* ─── Timeline ────────────────────────────── */

  .timeline {
    display: flex;
    flex-direction: column;
    gap: 28px;
  }

  .day-group { }

  .day-marker {
    display: flex;
    align-items: baseline;
    gap: 10px;
    margin-bottom: 10px;
  }

  .day-date {
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: 700;
    color: var(--color-text);
    letter-spacing: 0.04em;
  }

  .day-count {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--color-text-dim);
  }

  .day-commits {
    border-left: 1px solid var(--color-border);
    margin-left: 6px;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .commit {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    padding: 6px 0 6px 16px;
    position: relative;
  }

  .commit-dot {
    position: absolute;
    left: -4px;
    top: 12px;
    width: 7px;
    height: 7px;
    border-radius: 50%;
    border: 1px solid var(--color-border);
    background: var(--color-bg);
    flex-shrink: 0;
  }

  .commit[data-type="feat"] .commit-dot    { border-color: var(--color-accent); background: var(--color-accent); }
  .commit[data-type="arch"] .commit-dot    { border-color: #9b59b6; background: #9b59b6; }
  .commit[data-type="fix"] .commit-dot     { border-color: #e74c3c; background: #e74c3c; }
  .commit[data-type="design"] .commit-dot  { border-color: #1abc9c; background: #1abc9c; }
  .commit[data-type="docs"] .commit-dot    { border-color: #3498db; background: #3498db; }

  .commit-content {
    display: flex;
    flex-direction: column;
    gap: 3px;
    min-width: 0;
  }

  .commit-top {
    display: flex;
    align-items: baseline;
    gap: 7px;
    flex-wrap: wrap;
  }

  .commit-scope {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--color-accent);
    opacity: 0.8;
    flex-shrink: 0;
  }

  .commit-body {
    font-size: 13px;
    color: var(--color-text);
    line-height: 1.4;
  }

  .commit-hash {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--color-text-dim);
    opacity: 0.5;
    flex-shrink: 0;
  }

  .commit-type {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--color-text-dim);
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }
</style>
