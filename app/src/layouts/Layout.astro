---
interface Props {
  title?: string;
}

const { title = 'Sergey Knyazev' } = Astro.props;
---

<html lang="ru">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <!-- Применяем тему до рендера — предотвращает вспышку -->
    <script is:inline>
      (function () {
        const mode = localStorage.getItem('theme') || 'auto';
        const sys = window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark';
        document.documentElement.setAttribute('data-theme', mode === 'auto' ? sys : mode);
      })();
    </script>
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
